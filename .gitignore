# ─── secrets — NEVER commit ──────────────────────────────────────────────
**/.env
*.env
.env.*
*.pem
*.key
**/id_ed25519*
*service_account*.json
*credentials*.json
*gcp*key*.json

# ─── node / python deps ──────────────────────────────────────────────────
**/node_modules/
**/.venv/
**/venv/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/

# ─── databases & backups (regenerable, binary) ──────────────────────────
*.db
*.db-wal
*.db-shm
*.sqlite
*.bak
*.bak[0-9]

# ─── os / editor ─────────────────────────────────────────────────────────
.DS_Store
._*
Thumbs.db
*.swp

# ─── heavy generated media & assets — hosted on GCS, not in git ──────────
# every task's assets/ dir (images, video, audio, data, proxies) lives on GCS
input_assets/**/assets/
# any stray binary media anywhere in the tree
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.bmp
*.tif
*.tiff
*.heic
*.heif
*.pdf
*.zip
*.mp4
*.mov
*.webm
*.m4v
*.wav
*.mp3
*.m4a
*.aac
*.ogg
*.flac
*.psd
*.ai
*.indd
*.idml
*.eps

# ─── transient ───────────────────────────────────────────────────────────
scratchpad/
*.log
consistency_*.log
